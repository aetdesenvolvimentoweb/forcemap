{
  "name": "api_forcemap",
  "version": "1.0.0",
  "description": "Sistema que gerencia recursos disponíveis no serviço operacional do Corpo de Bombeiros Militar do Estado de Goiás",
  "author": "André David dos Santos <aetdesenvolvimentoweb@gmail.com>",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --config jest.unit.config.ts",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:unit:watch": "jest --config jest.unit.config.ts --watch",
    "test:integration:watch": "jest --config jest.integration.config.ts --watch",
    "test:unit:coverage": "jest --config jest.unit.config.ts --coverage",
    "test:integration:coverage": "jest --config jest.integration.config.ts --coverage",
    "test:staged": "jest --onlyChanged",
    "build": "tsc && tsc-alias",
    "build:clean": "rm -rf dist && pnpm build",
    "watch": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:imports": "eslint src/ --fix --rule 'unused-imports/no-unused-imports: error' --rule 'import/order: error'",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "format:lint": "pnpm format && pnpm lint:fix",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint/js": "^9.33.0",
    "@jest/globals": "^30.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "jiti": "^2.5.1",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1"
  },
  "keywords": [
    "mapa força",
    "CBMGO",
    "Corpo de Bombeiros",
    "API",
    "REST"
  ],
  "license": "ISC",
  "packageManager": "pnpm@10.14.0"
}
