# Arquivo de exemplo para variáveis de ambiente
# Copie para .env.local na Vercel ou configure nas Environment Variables

NODE_ENV=production
PORT=3000

# CORS Configuration
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database Configuration (quando implementar)
# DATABASE_URL=your_database_url_here

# API Configuration
API_VERSION=v1
